  "info": {
    "title": "Frapp API",
    "description": "The Operating System for Greek Life - Backend API",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "frapp",
      "description": ""
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "ClerkWebhookDto": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "description": "The data object of the webhook"
          },
          "object": {
            "type": "string",
            "description": "The object type"
          },
          "type": {
            "type": "string",
            "description": "The type of event"
          }
        },
        "required": [
          "data",
          "object",
          "type"
        ]
      },
      "OnboardingInitDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3,
            "description": "The formal name of the fraternity chapter"
          },
          "university": {
            "type": "string",
            "minLength": 2,
            "description": "The university or institution name"
          },
          "clerkOrganizationId": {
            "type": "string",
            "description": "Optional Clerk Organization ID if already created"
          }
        },
        "required": [
          "name",
          "university"
        ]
      },
      "CreateInvoiceDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Fall 2026 Dues"
          },
          "description": {
            "type": "string",
            "example": "Semester membership fees"
          },
          "amount": {
            "type": "number",
            "example": 50000,
            "description": "Amount in cents ($500.00)"
          },
          "userId": {
            "type": "string",
            "example": "user-uuid"
          },
          "dueDate": {
            "type": "string",
            "example": "2026-09-01T00:00:00Z"
          }
        },
        "required": [
          "title",
          "amount",
          "userId",
          "dueDate"
        ]
      },
      "CreateRoleDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3,
            "example": "Social Chair"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "events:create",
              "events:update"
            ]
          }
        },
        "required": [
          "name",
          "permissions"
        ]
      },
      "RoleResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "chapterId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "isSystem": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "chapterId",
          "name",
          "permissions",
          "isSystem",
          "createdAt"
        ]
      },
      "CreateInviteDto": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "description": "The role assigned to the new member",
            "example": "member"
          }
        },
        "required": [
          "role"
        ]
      },
      "AcceptInviteDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "The secure token from the invite"
          }
        },
        "required": [
          "token"
        ]
      },
      "CreateBackworkResourceDto": {
        "type": "object",
        "properties": {
          "courseCode": {
            "type": "string",
            "example": "CS101"
          },
          "courseName": {
            "type": "string",
            "example": "Intro to Computer Science"
          },
          "professorName": {
            "type": "string",
            "example": "Dr. Smith"
          },
          "term": {
            "type": "string",
            "example": "Fall 2024"
          },
          "title": {
            "type": "string",
            "example": "Final Exam 2024"
          },
          "s3Key": {
            "type": "string"
          },
          "fileHash": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "courseCode",
          "courseName",
          "professorName",
          "term",
          "title",
          "s3Key",
          "fileHash",
          "tags"
        ]
      },
      "AdjustPointsDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "example": "u1-uuid"
          },
          "amount": {
            "type": "number",
            "example": 10
          },
          "category": {
            "type": "string",
            "example": "SERVICE"
          },
          "description": {
            "type": "string",
            "example": "Helped with kitchen cleaning"
          },
          "metadata": {
            "type": "object"
          }
        },
        "required": [
          "userId",
          "amount",
          "category",
          "description"
        ]
      },
      "QrCheckInDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "example": "jwt-token-string"
          }
        },
        "required": [
          "token"
        ]
      },
      "CreateEventDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Chapter Meeting"
          },
          "description": {
            "type": "string",
            "example": "Weekly general assembly"
          },
          "startTime": {
            "type": "string",
            "example": "2026-02-14T18:00:00Z"
          },
          "endTime": {
            "type": "string",
            "example": "2026-02-14T19:00:00Z"
          },
          "pointValue": {
            "type": "number",
            "example": 10
          },
          "isMandatory": {
            "type": "boolean",
            "example": true
          }
        },
        "required": [
          "name",
          "startTime",
          "endTime",
          "pointValue",
          "isMandatory"
        ]
      },
      "RegisterPushTokenDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "example": "ExponentPushToken[xxxxxxxxxxxxxxxxxxxxxx]"
          },
          "deviceName": {
            "type": "string",
            "example": "iPhone 15 Pro"
          }
        },
        "required": [
          "token"
        ]
      },
      "CreateChatChannelDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "General"
          },
          "description": {
            "type": "string",
            "example": "Main chapter discussion"
          },
          "type": {
            "type": "string",
            "enum": [
              "PUBLIC",
              "PRIVATE",
              "ROLE_GATED"
            ],
            "default": "PUBLIC"
          },
          "allowedRoleIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "name",
          "type"
        ]
      },
      "SendChatMessageDto": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "example": "Hello everyone!"
          },
          "metadata": {
            "type": "object"
          }
        },
        "required": [
          "content"
        ]
      },
      "StartSessionDto": {
        "type": "object",
        "properties": {
          "geofenceId": {
            "type": "string",
            "example": "geofence-uuid"
          },
          "latitude": {
            "type": "number",
            "example": 37.7749
          },
          "longitude": {
            "type": "number",
            "example": -122.4194
          }
        },
        "required": [
          "geofenceId",
          "latitude",
          "longitude"
        ]
      },
      "HeartbeatDto": {
        "type": "object",
        "properties": {
          "latitude": {
            "type": "number",
            "example": 37.7749
          },
          "longitude": {
            "type": "number",
            "example": -122.4194
          }
        },
        "required": [
          "latitude",
          "longitude"
        ]
      },
      "MemberResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "chapterId": {
            "type": "string"
          },
          "roleIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "userId",
          "chapterId",
          "roleIds",
          "createdAt",
          "updatedAt"
        ]
      },
      "UpdateMemberRolesDto": {
        "type": "object",
        "properties": {
          "roleIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "example": [
              "role-uuid-1",
              "role-uuid-2"
            ]
          }
        },
        "required": [
          "roleIds"
        ]
      }
    }
  }
}