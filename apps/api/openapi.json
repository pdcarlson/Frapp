  "info": {
    "title": "Frapp API",
    "description": "The Operating System for Greek Life",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      },
      "chapter-id": {
        "type": "apiKey",
        "in": "header",
        "name": "x-chapter-id"
      }
    },
    "schemas": {
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "display_name": {
            "type": "string"
          },
          "bio": {
            "type": "string"
          },
          "avatar_url": {
            "type": "string"
          },
          "graduation_year": {
            "type": "number"
          },
          "current_city": {
            "type": "string"
          },
          "current_company": {
            "type": "string"
          }
        }
      },
      "CreateChapterDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "university": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "university"
        ]
      },
      "UpdateChapterDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "university": {
            "type": "string"
          },
          "accent_color": {
            "type": "string"
          },
          "donation_url": {
            "type": "string"
          }
        }
      },
      "UpdateMemberRolesDto": {
        "type": "object",
        "properties": {
          "role_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "role_ids"
        ]
      },
      "UpdateOnboardingDto": {
        "type": "object",
        "properties": {
          "has_completed_onboarding": {
            "type": "boolean"
          }
        },
        "required": [
          "has_completed_onboarding"
        ]
      },
      "CreateRoleDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "display_order": {
            "type": "number"
          },
          "color": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "permissions"
        ]
      },
      "UpdateRoleDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "display_order": {
            "type": "number"
          },
          "color": {
            "type": "string"
          }
        }
      },
      "TransferPresidencyDto": {
        "type": "object",
        "properties": {
          "target_member_id": {
            "type": "string"
          }
        },
        "required": [
          "target_member_id"
        ]
      },
      "CreateInviteDto": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "description": "Role name to assign to invited member"
          }
        },
        "required": [
          "role"
        ]
      },
      "BatchCreateInvitesDto": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "description": "Role name to assign"
          },
          "count": {
            "type": "number",
            "description": "Number of invites to generate"
          }
        },
        "required": [
          "role",
          "count"
        ]
      },
      "RedeemInviteDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          }
        },
        "required": [
          "token"
        ]
      },
      "CreateEventDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "start_time": {
            "type": "string"
          },
          "end_time": {
            "type": "string"
          },
          "point_value": {
            "type": "number",
            "default": 10
          },
          "is_mandatory": {
            "type": "boolean",
            "default": false
          },
          "recurrence_rule": {
            "type": "string",
            "description": "Recurrence rule (e.g. WEEKLY, BIWEEKLY, MONTHLY)"
          },
          "required_role_ids": {
